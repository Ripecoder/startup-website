{
  "name": "chatbot-pro-saas",
  "version": "1.0.0",
  "description": "AI-Powered Chatbot B2B SaaS Platform",
  "main": "index.html",
  "type": "module",
  "author": "Your Company",
  "license": "proprietary",
  "scripts": {
    "start": "python -m http.server 8000",
    "dev": "http-server -p 3000 -o",
    "build": "echo 'No build step needed for static site'",
    "test": "echo 'Tests not configured'",
    "backend-dev": "nodemon backend/server.js"
  },
  "keywords": [
    "chatbot",
